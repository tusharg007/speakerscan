# HuggingFace Access Token
# Required for pyannote/speaker-diarization-3.1 (gated model)
#
# Setup:
# 1. Create a token at https://huggingface.co/settings/tokens
# 2. Accept the license at https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Accept the license at https://huggingface.co/pyannote/segmentation-3.0
# 4. Copy this file to .env and replace the placeholder below
#
# On HF Spaces:
#   Go to Settings -> Secrets -> New Secret
#   Name: HF_TOKEN
#   Value: hf_your_token_here
#
HF_TOKEN=your_huggingface_token_here
